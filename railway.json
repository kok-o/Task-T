{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": [
      "apps/api/**",
      "packages/shared/**",
      "package.json",
      "package-lock.json"
    ],
    "buildCommand": "npm run build --workspace=api"
  },
  "deploy": {
    "startCommand": "npm run start --workspace=api",
    "restartPolicyType": "ON_FAILURE"
  }
}
